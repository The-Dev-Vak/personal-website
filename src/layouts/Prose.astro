---
import Base from './Base.astro';
import { withBase } from '../utils/url';

interface Props {
  frontmatter: {
    title: string;
    description?: string;
    kicker?: string;
    summary?: string;
    meta?: string[];
    cta?: { label: string; url: string };
  };
}
const { frontmatter } = Astro.props;
const fm = frontmatter;
---

<Base title={`${fm.title}, Kaveh Alemi`} description={fm.description ?? fm.summary}>
  <article class="mx-auto max-w-3xl px-5 py-16 sm:px-8 sm:py-20">
    <a
      href={withBase('/#projects')}
      class="font-mono text-sm text-muted underline-offset-4 hover:text-accent hover:underline"
    >
      ← back to projects
    </a>

    <header class="mt-8 border-b border-border pb-8">
      {fm.kicker && <p class="font-mono text-xs uppercase tracking-[0.2em] text-accent">{fm.kicker}</p>}
      <h1 class="mt-2 font-display text-3xl font-semibold tracking-tight text-text sm:text-4xl">{fm.title}</h1>
      {fm.summary && <p class="mt-4 text-lg leading-relaxed text-muted">{fm.summary}</p>}
      {
        fm.meta && (
          <ul class="mt-6 flex flex-wrap gap-2">
            {fm.meta.map((m) => (
              <li class="rounded-md border border-border px-2.5 py-1 font-mono text-xs text-muted">
                {m}
              </li>
            ))}
          </ul>
        )
      }
      {
        fm.cta && (
          <a
            href={fm.cta.url}
            target="_blank"
            rel="noopener"
            class="mt-6 inline-block rounded-md bg-accent px-4 py-2.5 text-sm font-medium text-bg transition-opacity hover:opacity-90"
          >
            {fm.cta.label} ↗
          </a>
        )
      }
    </header>

    <div class="prose mt-10">
      <slot />
    </div>
  </article>
</Base>

<style is:global>
  .prose {
    color: var(--muted);
    font-size: 1.0625rem;
    line-height: 1.75;
  }
  .prose > * + * {
    margin-top: 1.25rem;
  }
  .prose h2 {
    color: var(--ink);
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin-top: 2.75rem;
    margin-bottom: 0.25rem;
  }
  .prose h3 {
    color: var(--ink);
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 600;
    margin-top: 1.75rem;
  }
  .prose strong {
    color: var(--text);
    font-weight: 600;
  }
  .prose a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .prose ul,
  .prose ol {
    padding-left: 1.25rem;
  }
  .prose ul {
    list-style: none;
    padding-left: 0;
  }
  .prose ul > li {
    position: relative;
    padding-left: 1.25rem;
  }
  .prose ul > li::before {
    content: '▹';
    position: absolute;
    left: 0;
    color: var(--accent);
  }
  .prose ol {
    list-style: decimal;
  }
  .prose li + li {
    margin-top: 0.5rem;
  }
  .prose code {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.1em 0.4em;
    color: var(--text);
  }
  .prose pre {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1rem 1.25rem;
    overflow-x: auto;
    font-size: 0.85rem;
  }
  .prose pre code {
    background: none;
    border: none;
    padding: 0;
  }
  .prose blockquote {
    border-left: 2px solid var(--accent);
    padding-left: 1rem;
    color: var(--muted);
    font-style: italic;
  }
  .prose hr {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2.5rem 0;
  }
</style>
