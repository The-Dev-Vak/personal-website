---
import { CERT_GROUPS } from '../data/certifications';
import Section from './Section.astro';
import Reveal from './Reveal.astro';
import Logo from './Logo.astro';

const total = CERT_GROUPS.reduce((n, g) => n + g.certs.length, 0);
---

<Section id="certifications" num="05" kicker="certifications" title="Certified, repeatedly">
  <p class="-mt-4 mb-10 max-w-[680px] text-[18px] leading-[1.6] text-muted">
    {total} credentials and counting: 11x AWS Certified (incl. two Professional and two
    Specialty) and 4x Azure. The short version: I keep proving the depth on paper.
  </p>

  <Reveal class="rounded-2xl border border-line bg-surface p-[34px]">
    {
      CERT_GROUPS.map((group, gi) => (
        <div class={gi > 0 ? 'mt-3.5 border-t border-line2 pt-[26px]' : ''}>
          <div class="flex items-center justify-between gap-3.5 pb-[22px]">
            <div class="flex items-center gap-2.5">
              <Logo name={group.logo} label={group.issuer} size={32} />
              <h3 class="font-display text-[20px] font-semibold text-text">{group.issuer}</h3>
            </div>
            <span class="rounded-full border border-line px-3 py-1.5 font-mono text-[13px] text-accent">
              {group.tally}
            </span>
          </div>

          <div class="grid gap-3.5 sm:grid-cols-2 lg:grid-cols-3">
            {group.certs
              .filter((c) => c.featured)
              .map((c) => (
                <div class="rounded-xl border border-line bg-tile px-5 py-[18px]">
                  <div class="font-display text-[16px] font-semibold text-text">{c.name}</div>
                </div>
              ))}
          </div>

          {group.certs.some((c) => !c.featured) && (
            <div class="mt-3.5 flex flex-wrap gap-2">
              {group.certs
                .filter((c) => !c.featured)
                .map((c) => (
                  <span class="rounded-lg border border-line px-[11px] py-[7px] font-mono text-[12.5px] text-[#4A4E56]">
                    {c.name}
                  </span>
                ))}
            </div>
          )}
        </div>
      ))
    }
  </Reveal>
</Section>
