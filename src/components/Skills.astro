---
import { SKILLS } from '../data/skills';
import Section from './Section.astro';
import Reveal from './Reveal.astro';
import Logo from './Logo.astro';

// Inline glyphs for non-logo groups.
const glyphs: Record<string, string> = {
  code: '<path d="M8 6 3 12l5 6M16 6l5 6-5 6M13 4l-2 16"/>',
  platform:
    '<path d="M3 8l9-5 9 5-9 5-9-5z"/><path d="M3 8v8l9 5 9-5V8"/><path d="M12 13v8"/>',
  security: '<path d="M12 3l8 3v6c0 5-3.5 8-8 9-4.5-1-8-4-8-9V6l8-3z"/>',
  data: '<ellipse cx="12" cy="6" rx="8" ry="3"/><path d="M4 6v12c0 1.7 3.6 3 8 3s8-1.3 8-3V6"/><path d="M4 12c0 1.7 3.6 3 8 3s8-1.3 8-3"/>',
};
---

<Section id="skills" num="04" kicker="skills" title="The toolbox">
  <Reveal class="grid gap-10 rounded-2xl border border-line bg-surface p-10 sm:grid-cols-2">
    {
      SKILLS.map((group) => (
        <div>
          <div class="mb-4 flex items-center gap-2.5">
            {group.icon === 'aws' || group.icon === 'azure' ? (
              <Logo name={group.icon === 'aws' ? 'aws' : 'microsoft'} label={group.label} size={28} />
            ) : (
              <span class="grid h-7 w-7 place-items-center rounded-lg border border-line bg-tile text-accent">
                <svg
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.7"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  set:html={glyphs[group.icon]}
                />
              </span>
            )}
            <h3 class="font-display text-[18px] font-semibold text-text">{group.label}</h3>
          </div>
          <ul class="flex flex-wrap gap-2">
            {group.items.map((item) => (
              <li class="rounded-lg border border-line bg-tile px-[11px] py-[7px] font-mono text-[13px] text-[#4A4E56]">
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </Reveal>
</Section>
