---
import { SITE } from '../config/site';
import { PROJECTS } from '../data/projects';
import { withBase } from '../utils/url';
import Section from './Section.astro';
import Reveal from './Reveal.astro';
import Logo from './Logo.astro';

const featured = PROJECTS.find((p) => p.slug === 'latchkey')!;
const rest = PROJECTS.filter((p) => p.slug !== 'latchkey');
const latchkeyMetrics = [
  ['Venture', 'backed'],
  ['Profitable', 'and growing'],
  ['Agentic', 'AI backend'],
];
const externalFor = (slug: string) =>
  slug === 'worddrop' ? { label: 'App Store', url: SITE.links.appStore } : undefined;
---

<Section id="projects" num="03" kicker="projects" title="What I've built">
  <!-- featured: latchkey -->
  <Reveal
    class="grid items-center gap-10 rounded-2xl border border-line border-t-2 border-t-accent bg-surface p-9 md:grid-cols-2"
  >
    <div>
      <Logo name="latchkey" label="latchkey" size={46} class="mb-5" />
      <div class="font-mono text-[11.5px] font-medium uppercase tracking-[0.18em] text-accent">
        {featured.kind}
      </div>
      <h3 class="mt-3 font-display text-[30px] font-semibold tracking-[-0.02em] text-text">
        {featured.name}
      </h3>
      <p class="mt-3.5 max-w-[460px] text-[18px] leading-[1.58] text-muted">{featured.blurb}</p>
      <div class="mt-[22px] flex gap-5 font-mono text-[13.5px]">
        <a href={withBase('/projects/latchkey')} class="text-accent hover:underline">→ case study</a>
        <a href={featured.external?.url} target="_blank" rel="noopener" class="text-muted hover:text-text">
          ↗ latchkey.dev
        </a>
      </div>
    </div>
    <div class="flex flex-col gap-3">
      {
        latchkeyMetrics.map(([n, l]) => (
          <div class="flex items-center justify-between rounded-xl border border-line bg-tile px-[18px] py-4">
            <span class="font-display text-2xl font-bold tracking-[-0.02em] text-text">{n}</span>
            <span class="font-mono text-[11px] uppercase tracking-[0.12em] text-subtle">{l}</span>
          </div>
        ))
      }
    </div>
  </Reveal>

  <!-- the rest -->
  <div class="mt-5 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
    {
      rest.map((p) => {
        const ext = p.external ?? externalFor(p.slug);
        const caseHref = p.href ? withBase(p.href) : undefined;
        return (
          <Reveal
            as="article"
            class="flex flex-col gap-3.5 rounded-2xl border border-line bg-surface p-[26px] transition-colors hover:border-accent"
          >
            <div class="font-mono text-[11.5px] font-medium uppercase tracking-[0.18em] text-accent">
              {p.kind}
            </div>
            <div class="flex items-start justify-between gap-3">
              <h4 class="font-display text-[22px] font-semibold tracking-[-0.01em] text-text">{p.name}</h4>
              {p.icon && (
                <img
                  src={withBase(p.icon)}
                  alt={`${p.name} icon`}
                  width="44"
                  height="44"
                  loading="lazy"
                  class="h-11 w-11 flex-none rounded-[11px] border border-line object-cover"
                />
              )}
            </div>
            <p class="flex-1 text-[16px] leading-[1.55] text-muted">{p.blurb}</p>
            <div class="flex flex-wrap gap-2">
              {p.metrics.map((m) => (
                <span class="rounded-md border border-line px-2.5 py-1 font-mono text-xs text-[#4A4E56]">
                  {m}
                </span>
              ))}
            </div>
            {(caseHref || ext) && (
              <div class="flex gap-[18px] font-mono text-[13px]">
                {caseHref && (
                  <a href={caseHref} class="text-accent hover:underline">
                    → case study
                  </a>
                )}
                {ext && (
                  <a
                    href={ext.url}
                    target="_blank"
                    rel="noopener"
                    class={caseHref ? 'text-muted hover:text-text' : 'text-accent hover:underline'}
                  >
                    ↗ {ext.label}
                  </a>
                )}
              </div>
            )}
          </Reveal>
        );
      })
    }
  </div>
</Section>
