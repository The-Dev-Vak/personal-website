---
import { SITE } from '../config/site';
import { withBase } from '../utils/url';

interface Props {
  home?: boolean;
}
const { home = false } = Astro.props;

const hrefFor = (anchor: string) => (home ? anchor : withBase(`/${anchor}`));
const homeHref = withBase('/');
---

<header
  class="sticky top-0 z-50 border-b border-line2 backdrop-blur-md"
  style="background:rgba(250,250,247,.72);"
>
  <nav
    class="mx-auto flex h-16 max-w-[1180px] items-center justify-between px-6 sm:px-8"
    aria-label="Primary"
  >
    <a href={homeHref} class="font-mono text-[15px] font-medium text-text">
      <span class="text-subtle">~/</span>kaveh-alemi
    </a>

    <div class="flex items-center gap-0.5">
      <ul class="mr-1 hidden items-center gap-0.5 md:flex">
        {
          SITE.nav.map((item) => (
            <li>
              <a
                href={hrefFor(item.href)}
                class="rounded-lg px-2.5 py-2 font-mono text-[13px] text-muted transition-colors hover:bg-black/5 hover:text-text"
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
      <button
        type="button"
        onclick="window.openCmdK && window.openCmdK()"
        class="ml-1 hidden items-center gap-1.5 rounded-lg border border-line px-2.5 py-1.5 font-mono text-[12px] text-muted transition-colors hover:border-accent hover:text-text sm:inline-flex"
        aria-label="Open command palette"
      >
        ⌘ K
      </button>
    </div>
  </nav>
</header>
