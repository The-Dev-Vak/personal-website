---
import { SITE } from '../config/site';
import { withBase } from '../utils/url';
import { EXPERIENCE, INTERNSHIPS } from '../data/experience';
import Section from './Section.astro';
import Reveal from './Reveal.astro';
import Logo from './Logo.astro';
---

<Section id="experience" num="02" kicker="experience" title="Where I've shipped">
  <div class="-mt-2">
    {
      EXPERIENCE.map((job) => (
        <Reveal
          as="div"
          class="grid grid-cols-1 items-baseline gap-x-6 gap-y-1.5 border-t border-line2 py-[34px] sm:grid-cols-[1fr_auto]"
        >
          <div class="flex items-start gap-3.5">
            <Logo name={job.logo} label={job.company} size={42} class="mt-1" />
            <div>
              <h3 class="font-display text-2xl font-semibold tracking-[-0.01em] text-text">
                {job.href ? (
                  <a href={job.href} target="_blank" rel="noopener" class="hover:text-accent">
                    {job.company}
                  </a>
                ) : (
                  job.company
                )}
                <span class="font-normal text-subtle"> · {job.role}</span>
              </h3>
              {job.location && (
                <div class="mt-1.5 font-mono text-[13px] text-subtle">{job.location}</div>
              )}
            </div>
          </div>
          <div class="font-mono text-[13px] whitespace-nowrap text-muted">{job.dates}</div>
          <ul class="col-span-full mt-5 flex max-w-[900px] flex-col gap-3.5">
            {job.points.map((p) => (
              <li class="flex gap-3.5 text-[17.5px] leading-[1.55] text-muted">
                <span class="mt-[11px] h-1.5 w-1.5 flex-none rounded-full bg-accent" />
                <span set:html={p.replace(/\$[\w.+]+|\b\d+x\b|Project Pronghorn Blue|SecureSight/g, (m) => `<b class=\"font-semibold text-text\">${m}</b>`)} />
              </li>
            ))}
          </ul>
        </Reveal>
      ))
    }
  </div>

  <Reveal class="mt-12">
    <div class="mb-5 font-mono text-xs uppercase tracking-[0.22em] text-subtle">
      earlier · internships
    </div>
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        INTERNSHIPS.map((job) => (
          <div class="rounded-xl border border-line bg-surface p-[22px]">
            <div class="flex items-baseline justify-between gap-2.5">
              <h4 class="font-display text-[17px] font-semibold text-text">{job.company}</h4>
              <span class="font-mono text-[11.5px] whitespace-nowrap text-subtle">{job.dates}</span>
            </div>
            <div class="mt-0.5 text-sm text-muted">{job.role}</div>
            <p class="mt-3 text-[15px] leading-[1.5] text-muted">{job.blurb}</p>
          </div>
        ))
      }
    </div>
  </Reveal>
</Section>
