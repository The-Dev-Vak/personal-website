---
// Consistent section wrapper matching the design system: numbered mono label
// with an accent bar that draws in, then a Space Grotesk heading.
interface Props {
  id: string;
  num: string;
  kicker: string;
  title: string;
  avatar?: string;
  avatarAlt?: string;
  class?: string;
}
const { id, num, kicker, title, avatar, avatarAlt = '', class: className = '' } = Astro.props;
---

<section
  id={id}
  class={`mx-auto max-w-[1180px] border-t border-line2 px-6 py-20 sm:px-8 sm:py-[104px] ${className}`}
>
  <div class="mb-10 flex items-center gap-5">
    {
      avatar && (
        <img
          src={avatar}
          alt={avatarAlt}
          width="80"
          height="80"
          loading="lazy"
          decoding="async"
          class="h-[72px] w-[72px] flex-none rounded-full border border-line object-cover sm:h-20 sm:w-20"
        />
      )
    }
    <div>
      <div class="flex items-center gap-3.5">
        <span class="draw-line h-0.5 w-11 bg-accent" data-reveal></span>
        <span class="font-mono text-xs font-medium uppercase tracking-[0.22em] text-accent">
          {num} — {kicker}
        </span>
      </div>
      <h2
        class="mt-4 font-display text-[clamp(34px,4.4vw,52px)] font-semibold leading-[1.02] tracking-[-0.025em] text-text"
      >
        {title}
      </h2>
    </div>
  </div>
  <slot />
</section>
